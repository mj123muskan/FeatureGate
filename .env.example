# Admin token — required to sign in to the UI and call the admin API.
# Generate one, e.g.:  openssl rand -hex 24
ADMIN_TOKEN=change-me

# Storage backend: "file" (default) or "postgres".
STORE=file

# Used when STORE=file (path to the JSON data file).
DATA_FILE=data/flags.json

# Used when STORE=postgres (any Postgres connection string).
# DATABASE_URL=postgres://user:pass@host:5432/dbname
